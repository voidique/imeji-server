# ───────────────────────── Server ─────────────────────────
# Backend runs on 3005; frontend (Next dev) runs on 3000.
NODE_ENV=development
PORT=3005

# ──────────────────────── Database ────────────────────────
# Neon > Connection string (pooled). sslmode=require 포함.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ────────────────────── Authentication ────────────────────
# 32자 이상. 생성: openssl rand -base64 32
BETTER_AUTH_SECRET=
# This server's own URL (must match where the backend actually listens).
BETTER_AUTH_URL=http://localhost:3005

# ────────────────────── CORS / 보안 ───────────────────────
# Allowed frontend origins, comma-separated (used by both CORS and CSRF).
TRUSTED_ORIGINS=http://localhost:3000

# Rate limit (DDoS / brute-force 완화)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# 요청 본문 최대 크기(byte) / 요청 타임아웃(ms)
MAX_BODY_SIZE=1048576
REQUEST_TIMEOUT_MS=15000

# ───────────────────── AI provider ────────────────────────
OPENAI_API_KEY=
# Shared model for chat + mindmap generation (reasoning model).
OPENAI_MODEL=gpt-5.4-mini
