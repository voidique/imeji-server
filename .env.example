# ───────────────────────── Server ─────────────────────────
NODE_ENV=development
PORT=3000

# ──────────────────────── Database ────────────────────────
# Neon > Connection string (pooled). sslmode=require 포함.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ────────────────────── Authentication ────────────────────
# 32자 이상. 생성: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ────────────────────── CORS / 보안 ───────────────────────
# 허용 origin. 쉼표로 여러 개 (CORS + CSRF 양쪽에 적용).
TRUSTED_ORIGINS=http://localhost:3000

# Rate limit (DDoS / brute-force 완화)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# 요청 본문 최대 크기(byte) / 요청 타임아웃(ms)
MAX_BODY_SIZE=1048576
REQUEST_TIMEOUT_MS=15000

# ───────────────────── AI provider ────────────────────────
OPENAI_API_KEY=
